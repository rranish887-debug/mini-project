modules = ["python-3.10"]
run = "python app.py"
hidden = [".pythonlibs"]

[nix]
channel = "stable-23_11"

[unitTest]
language = "python3"

[deployment]
run = ["sh", "-c", "python app.py"]
deploymentTarget = "cloudrun"

[env]
PYTHONPATH = "${PYTHONPATH}:${REPL_HOME}"

[[ports]]
localPort = 5000
externalPort = 80
